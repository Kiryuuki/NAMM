# NAMM Environment Variables Template
# Copy this file to .env and fill in your real service details

# Jellyfin
VITE_JELLYFIN_URL=http://192.168.1.X:8096
VITE_JELLYFIN_KEY=your_jellyfin_api_key_here
VITE_JELLYFIN_USER_ID=your_jellyfin_user_id_here

# Radarr
VITE_RADARR_URL=http://192.168.1.X:7878
VITE_RADARR_KEY=your_radarr_api_key_here

# Sonarr
VITE_SONARR_URL=http://192.168.1.X:8989
VITE_SONARR_KEY=your_sonarr_api_key_here

# Prowlarr
VITE_PROWLARR_URL=http://192.168.1.X:9696
VITE_PROWLARR_KEY=your_prowlarr_api_key_here

# TMDB (for discovery metadata)
VITE_TMDB_KEY=your_tmdb_api_key_here
